# Copy to .env and fill in your values:
#   cp .env.example .env

# Required: generate with: openssl rand -hex 32
APP_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# Absolute path to this project directory (used by updater sidecar; e.g. /home/user/Docker/project-nomad)
PROJECT_NOMAD_HOST_PATH=/path/to/project-nomad

# Run admin as your user so storage files are owned by you and UI can manage containers (Docker socket).
# Use your UID and the host docker group GID (getent group docker):
NOMAD_UID=1000
NOMAD_GID=100

# HTTP port on the host for the NOMAD UI
NOMAD_HTTP_PORT=8180

# Public URL that clients use to access NOMAD (use your server IP/domain if not local)
NOMAD_URL=http://localhost:8180

# Optional: HTTPS URLs for installable apps behind Traefik (re-applied on every admin start).
# See traefik-nomad-apps.snippet.yaml and docs/reverse-proxy.md.
# NOMAD_APP_KIWIX_URL=https://kiwix.example.com
# NOMAD_APP_CYBERCHEF_URL=https://cyberchef.example.com
# NOMAD_APP_FLATNOTES_URL=https://flatnotes.example.com
# NOMAD_APP_KOLIBRI_URL=https://kolibri.example.com

# Database credentials (choose strong passwords)
DB_USER=nomad_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD
