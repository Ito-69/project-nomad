# Traefik mode — use when NOMAD is published via a reverse proxy (HTTPS).
# Requires Traefik routes deployed first (see docs/traefik.md), then:
#   cp .env.traefik.example .env   # edit domains, then: docker compose up -d admin

NOMAD_URL=https://nomad.example.com

NOMAD_APP_KIWIX_URL=https://kiwix.example.com
NOMAD_APP_CYBERCHEF_URL=https://cyberchef.example.com
NOMAD_APP_FLATNOTES_URL=https://flatnotes.example.com
NOMAD_APP_KOLIBRI_URL=https://kolibri.example.com

# Dozzle: Settings → "Service Logs & Metrics" opens nomad.example.com:9999 (hardcoded in NOMAD UI).
# Traefik must expose TCP+TLS on port 9999 for that link (see docs/traefik.md).
