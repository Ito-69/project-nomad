# LAN mode — direct IP access (default, no reverse proxy).
# Copy into .env and replace YOUR_SERVER_IP with your Docker host LAN address.

NOMAD_URL=http://YOUR_SERVER_IP:8180

NOMAD_APP_KIWIX_URL=http://YOUR_SERVER_IP:8090
NOMAD_APP_CYBERCHEF_URL=http://YOUR_SERVER_IP:8100
NOMAD_APP_FLATNOTES_URL=http://YOUR_SERVER_IP:8200
NOMAD_APP_KOLIBRI_URL=http://YOUR_SERVER_IP:8300

# Dozzle: Settings opens http://YOUR_SERVER_IP:9999 automatically (no .env var needed)
